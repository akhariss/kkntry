<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kkn_program_tree" model="ir.ui.view">
        <field name="name">tipd_kkn.program.tree</field>
        <field name="model">tipd_kkn.program</field>
        <field name="arch" type="xml">
            <list string="Program KKN">
                <field name="name"/>
                <field name="year"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_kkn_program_form" model="ir.ui.view">
        <field name="name">tipd_kkn.program.form</field>
        <field name="model">tipd_kkn.program</field>
        <field name="arch" type="xml">
            <form string="Program KKN">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,done" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nama Program"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="year"/>
                            <field name="theme"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Kelompok KKN" name="groups">
                            <field name="group_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="location_id"/>
                                    <field name="supervisor_id"/>
                                    <field name="participant_count"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_tipd_kkn_program" model="ir.actions.act_window">
        <field name="name">Program KKN</field>
        <field name="res_model">tipd_kkn.program</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
