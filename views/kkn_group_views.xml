<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kkn_group_tree" model="ir.ui.view">
        <field name="name">tipd_kkn.group.tree</field>
        <field name="model">tipd_kkn.group</field>
        <field name="arch" type="xml">
            <list string="Kelompok KKN">
                <field name="name"/>
                <field name="program_id"/>
                <field name="location_id"/>
                <field name="supervisor_id"/>
                <field name="participant_count"/>
            </list>
        </field>
    </record>

    <record id="view_kkn_group_form" model="ir.ui.view">
        <field name="name">tipd_kkn.group.form</field>
        <field name="model">tipd_kkn.group</field>
        <field name="arch" type="xml">
            <form string="Kelompok KKN">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nama Kelompok"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="program_id"/>
                            <field name="location_id"/>
                            <field name="supervisor_id"/>
                        </group>
                        <group>
                            <field name="participant_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Anggota Kelompok" name="participants">
                            <field name="participant_ids">
                                <list>
                                    <field name="partner_id"/>
                                    <field name="nim"/>
                                    <field name="faculty"/>
                                    <field name="major"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                        <page string="Kegiatan Harian" name="activities">
                            <field name="activity_ids">
                                <list>
                                    <field name="date"/>
                                    <field name="name"/>
                                    <field name="participant_id"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_tipd_kkn_group" model="ir.actions.act_window">
        <field name="name">Kelompok KKN</field>
        <field name="res_model">tipd_kkn.group</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
